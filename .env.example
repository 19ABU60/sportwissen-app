# Umgebungsvariablen für Docker Deployment
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# Ihre Domain (mit https://)
DOMAIN_URL=https://ihre-domain.de

# MongoDB Atlas Connection String
# Ersetzen Sie <username>, <password> und <cluster> mit Ihren Werten
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Datenbank Name
DB_NAME=sportwissen
